{
  "name": "vamsa",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "postinstall": "[ -f packages/api/src/drizzle/schema/index.ts ] && bun run db:generate || true",
    "// === Development ===": "",
    "dev": "bun scripts/dev.ts",
    "dev:pg": "DB_DRIVER=postgres bun scripts/dev.ts",
    "dev:web-only": "bun run --filter @vamsa/web dev",
    "dev:ai": "bun run --filter @vamsa/ai dev",
    "// === Build ===": "",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter @vamsa/web build",
    "build:ai": "bun run --filter @vamsa/ai build",
    "preview": "bun run --filter @vamsa/web preview",
    "// === Code Quality ===": "",
    "cmd": "bun scripts/cmd.ts",
    "quality": "bun scripts/check-all.ts",
    "quality:ci": "bun run format:check && bun run lint && bun run typecheck && bun run build",
    "ci": "bun run quality:ci && bun run test:ci",
    "check": "bun scripts/check-all.ts",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint .",
    "lint:fix": "NODE_OPTIONS=--max-old-space-size=8192 eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run --filter '*' typecheck",
    "// === Testing ===": "",
    "test": "bun scripts/test.ts unit",
    "test:ci": "bun scripts/test.ts ci",
    "test:focus": "bun scripts/test.ts focus",
    "test:integration": "bun scripts/test.ts integration",
    "test:unit": "bun scripts/test.ts unit",
    "test:e2e": "bun scripts/test.ts e2e",
    "test:perf": "bun scripts/test.ts focus --suite perf",
    "test:visual": "bun scripts/test.ts focus --suite visual",
    "test:visual:update": "bun scripts/test.ts focus --suite visual --update-snapshots",
    "test:int": "bun scripts/test.ts integration --db sqlite",
    "test:int:sqlite": "bun scripts/test.ts integration --db sqlite",
    "test:int:postgres": "bun scripts/test.ts integration --db postgres",
    "test:mutation": "bun scripts/test.ts mutation",
    "analyze": "bun run --filter @vamsa/web analyze",
    "check:bundle": "bun run --filter @vamsa/web check:bundle",
    "lighthouse": "bunx @lhci/cli autorun",
    "load-test": "bun scripts/cmd.ts load run mixed",
    "load-test:auth": "bun scripts/cmd.ts load run auth",
    "load-test:people": "bun scripts/cmd.ts load run people",
    "load-test:search": "bun scripts/cmd.ts load run search",
    "load-test:detail": "bun scripts/cmd.ts load run detail",
    "// === Database ===": "",
    "db:generate": "bun scripts/cmd.ts db generate",
    "db:push": "bun scripts/cmd.ts db push",
    "db:migrate": "bun scripts/cmd.ts db migrate",
    "db:seed": "bun scripts/cmd.ts db seed",
    "db:seed:dev": "bun scripts/cmd.ts db seed-dev",
    "db:seed:e2e": "bun scripts/cmd.ts db seed-e2e",
    "db:studio": "bun scripts/cmd.ts db studio",
    "db:backup": "bun scripts/cmd.ts db backup",
    "db:backup:pre-migration": "bun scripts/cmd.ts db backup-pre-migration",
    "db:backup:status": "bun scripts/cmd.ts db backup-status",
    "db:backup:verify": "bun scripts/cmd.ts db backup-verify",
    "db:backup:verify:docker": "bun scripts/cmd.ts db backup-verify-docker",
    "db:migrate:dry-run": "bun scripts/cmd.ts db migrate-dry-run",
    "db:restore": "bun scripts/cmd.ts db restore",
    "db:restore:list": "bun scripts/cmd.ts db restore-list",
    "// === Docker (Production) ===": "",
    "docker": "bun scripts/cmd.ts docker up",
    "docker:down": "bun scripts/cmd.ts docker down",
    "docker:logs": "bun scripts/cmd.ts docker logs",
    "docker:build": "bun scripts/cmd.ts docker build",
    "docker:build:ssl-skip": "bun scripts/cmd.ts docker build-ssl-skip",
    "// === Docker (Development) ===": "",
    "docker:dev": "bun scripts/cmd.ts docker dev",
    "docker:dev:app": "bun scripts/cmd.ts docker dev-app",
    "docker:dev:down": "bun scripts/cmd.ts docker dev-down",
    "docker:dev:logs": "bun scripts/cmd.ts docker dev-logs",
    "// === Docker (E2E) ===": "",
    "docker:e2e": "bun scripts/cmd.ts docker e2e",
    "docker:e2e:down": "bun scripts/cmd.ts docker e2e-down",
    "docker:e2e:build": "bun scripts/cmd.ts docker e2e-build",
    "// === Docker (Backup) ===": "",
    "docker:backup": "bun scripts/cmd.ts docker backup",
    "docker:backup:down": "bun scripts/cmd.ts docker backup-down",
    "// === Production (bm2) ===": "",
    "prod:start": "bun scripts/cmd.ts prod start",
    "prod:stop": "bun scripts/cmd.ts prod stop",
    "prod:status": "bun scripts/cmd.ts prod status",
    "prod:logs": "bun scripts/cmd.ts prod logs",
    "prod:reload": "bun scripts/cmd.ts prod reload",
    "// === Observability ===": "",
    "observability": "bun scripts/cmd.ts obs up",
    "observability:down": "bun scripts/cmd.ts obs down",
    "observability:logs": "bun scripts/cmd.ts obs logs",
    "// === Documentation ===": "",
    "docs:prebuild": "bun scripts/cmd.ts docs prebuild",
    "docs:dev": "bun scripts/cmd.ts docs dev",
    "docs:build": "bun scripts/cmd.ts docs build",
    "docs:build:docker": "bun scripts/cmd.ts docs build-docker",
    "// === Utilities ===": "",
    "setup": "bun scripts/setup-env.ts",
    "setup:docker": "bun scripts/setup-env.ts --docker",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "release": "bunx semantic-release",
    "release:dry": "bunx semantic-release --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.2.4",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.2",
    "html2canvas": "1.4.1",
    "ical-generator": "10.1.0",
    "maplibre-gl": "5.19.0",
    "rss": "1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@lhci/cli": "0.15.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "latest",
    "@types/node": "25.6.0",
    "@vitest/coverage-istanbul": "4.1.4",
    "better-sqlite3": "12.9.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.6.0",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "overrides": {
    "@react-email/render": "^2.0.4",
    "drizzle-orm": "0.45.2",
    "hono": ">=4.12.3",
    "lodash": ">=4.17.23",
    "playwright-core": "1.58.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "bash -c 'bun run typecheck'"
    ],
    "*.{js,jsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
